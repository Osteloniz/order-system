// Prisma schema for Order System
// Comentarios intencionais para facilitar leitura e manutencao.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Enums alinhados aos tipos do projeto (lib/types.ts)
enum StatusPedido {
  FEITO
  ACEITO
  PREPARACAO
  ENTREGUE
  CANCELADO
}

enum TipoPagamento {
  PIX
  DINHEIRO
  CARTAO
}

enum TipoCartao {
  CREDITO
  DEBITO
}

enum TipoEntrega {
  ENTREGA
  RETIRADA
  RESERVA_PAULISTANO
  ENCOMENDA
}

enum TipoCupom {
  FIXO
  PERCENTUAL
}

enum StatusPagamento {
  NAO_APLICAVEL
  PENDENTE
  APROVADO
  RECUSADO
  CANCELADO
  REEMBOLSADO
}

enum StatusContaPagar {
  PENDENTE
  PAGO
  CANCELADO
}

enum InviteStatus {
  PENDING
  USED
  EXPIRED
  REVOKED
}

enum AuthAuditAction {
  LOGIN_SUCCESS
  LOGIN_FAILURE
  LOGOUT
  INVITE_CREATED
  INVITE_USED
  USER_CREATED
}

enum LogOperacaoTipo {
  AJUSTE_ESTOQUE
  REGISTRO_PRODUCAO
  RESERVA_ENCOMENDA
  LIBERACAO_RESERVA
  BAIXA_ESTOQUE_ENTREGA
  ESTORNO_ESTOQUE
  SINCRONIZACAO_LEGADA
  PEDIDO_CRIADO
  PEDIDO_EDITADO
  PEDIDO_STATUS_ALTERADO
  PEDIDO_EXCLUIDO
}

model Configuracao {
  id                  String   @id @default(uuid())
  nomeEstabelecimento String
  enderecoRetirada    String
  freteBase           Int      @default(500) // centavos (ate o raio base)
  freteRaioKm         Float    @default(3) // km
  freteKmExcedente    Int      @default(100) // centavos por km excedente
  estabelecimentoLat  Float    @default(0)
  estabelecimentoLng  Float    @default(0)
  envioAutomaticoWhatsappStatus Boolean @default(true)
  mensagemStatusAceito String?
  mensagemStatusPreparacao String?
  mensagemStatusEntregue String?
  criadoEm            DateTime @default(now())
  atualizadoEm        DateTime @updatedAt

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  @@unique([tenantId])
}

model Categoria {
  id          String   @id @default(uuid())
  nome        String
  ordem       Int
  criadoEm    DateTime @default(now())
  atualizadoEm DateTime @updatedAt
  produtos    Produto[]

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])
}

model Produto {
  id          String   @id @default(uuid())
  nome        String
  descricao   String?
  categoriaId String
  preco       Int      // centavos
  ativo       Boolean  @default(true)
  imagemUrl   String?
  imagens     String[] @default([])
  ordem       Int
  criadoEm    DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  categoria   Categoria @relation(fields: [categoriaId], references: [id])
  itensPedido ItemPedido[]
  estoqueProdutos ProdutoEstoque[]
  producaoRegistros ProducaoRegistro[]

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  @@index([categoriaId])
  @@index([ativo])
}

model Pedido {
  id              String        @id @default(uuid())
  clienteId       String?
  status          StatusPedido  @default(FEITO)
  estoqueReservadoEm DateTime?
  estoqueBaixadoEm DateTime?
  clienteNome     String
  clienteTelefone String?
  clienteWhatsapp String?
  clienteBloco    String?
  clienteApartamento String?
  observacoesPedido String?
  responsavelPedido String?
  destinatariosPedido String?
  separacaoResponsavel Json?
  levadoEm        DateTime?
  pagamento       TipoPagamento
  tipoCartao      TipoCartao?
  statusPagamento StatusPagamento @default(NAO_APLICAVEL)
  mercadoPagoPaymentId String?
  mercadoPagoPreferenceId String?
  tipoEntrega     TipoEntrega
  encomendaPara   DateTime?
  enderecoEntrega String?
  enderecoRetirada String
  frete           Int
  subtotal        Int
  total           Int
  motivoCancelamento String?
  distanciaKm     Float?
  descontoValor   Int?
  cupomCodigoSnapshot String?
  cupomId         String?
  criadoEm        DateTime      @default(now())
  atualizadoEm    DateTime      @updatedAt
  itens           ItemPedido[]

  cliente         Cliente? @relation(fields: [clienteId], references: [id])
  cupom           Cupom? @relation(fields: [cupomId], references: [id])

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  @@index([clienteTelefone])
  @@index([clienteId])
  @@index([status])
  @@index([statusPagamento])
  @@index([mercadoPagoPaymentId])
  @@index([criadoEm])
  @@index([encomendaPara])
}

model Cliente {
  id                 String   @id @default(uuid())
  tenantId           String
  nome               String
  telefone           String?
  whatsapp           String?
  clienteBloco       String?
  clienteApartamento String?
  observacoes        String?
  mimosEntregues     Int      @default(0)
  criadoEm           DateTime @default(now())
  atualizadoEm       DateTime @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  pedidos Pedido[]

  @@unique([tenantId, telefone])
  @@index([telefone])
}

model ItemPedido {
  id                  String   @id @default(uuid())
  pedidoId            String
  produtoId           String
  nomeProdutoSnapshot String
  precoUnitarioSnapshot Int
  quantidade          Int
  totalItem           Int
  quantidadePreparada Int      @default(0)
  preparadoEm         DateTime?

  pedido   Pedido  @relation(fields: [pedidoId], references: [id])
  produto  Produto @relation(fields: [produtoId], references: [id])

  @@index([pedidoId])
  @@index([produtoId])
}

model ProdutoEstoque {
  id                   String   @id @default(uuid())
  tenantId             String
  produtoId            String
  quantidadeDisponivel Int      @default(0)
  quantidadeReservada  Int      @default(0)
  criadoEm             DateTime @default(now())
  atualizadoEm         DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  produto Produto @relation(fields: [produtoId], references: [id])

  @@unique([tenantId, produtoId])
  @@index([produtoId])
}

model ProducaoRegistro {
  id           String   @id @default(uuid())
  tenantId     String
  produtoId    String
  quantidade   Int
  dataProducao DateTime
  criadoEm     DateTime @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  produto Produto @relation(fields: [produtoId], references: [id])

  @@index([tenantId, dataProducao])
  @@index([produtoId])
}

model LogOperacao {
  id               String          @id @default(uuid())
  tenantId         String
  tipo             LogOperacaoTipo
  produtoId        String?
  produtoNome      String?
  pedidoId         String?
  pedidoNumero     String?
  quantidade       Int?
  saldoDisponivel  Int?
  saldoReservado   Int?
  descricao        String
  metadata         Json?
  actorNome        String?
  criadoEm         DateTime        @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, criadoEm])
  @@index([tenantId, tipo, criadoEm])
  @@index([pedidoId])
  @@index([produtoId])
}

model Cupom {
  id        String     @id @default(uuid())
  codigo    String
  tipo      TipoCupom
  valor     Int        // centavos (FIXO) ou percentual (PERCENTUAL)
  ativo     Boolean    @default(true)
  expiraEm  DateTime
  maxUsos   Int
  usos      Int        @default(0)
  criadoEm  DateTime   @default(now())
  atualizadoEm DateTime @updatedAt

  pedidos   Pedido[]

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, codigo])
}

model ContaPagar {
  id          String            @id @default(uuid())
  tenantId    String
  descricao   String
  categoria   String?
  fornecedor  String?
  observacoes String?
  valor       Int
  vencimento  DateTime
  pagoEm      DateTime?
  status      StatusContaPagar  @default(PENDENTE)
  criadoEm    DateTime          @default(now())
  atualizadoEm DateTime         @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, vencimento])
  @@index([tenantId, status, vencimento])
}

model Tenant {
  id          String   @id @default(uuid())
  nome        String
  slug        String   @unique
  isOpen      Boolean  @default(true)
  criadoEm    DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  categorias  Categoria[]
  produtos    Produto[]
  pedidos     Pedido[]
  clientes    Cliente[]
  cupons      Cupom[]
  configuracao Configuracao?
  adminUsers  AdminUser[]
  estoqueProdutos ProdutoEstoque[]
  producaoRegistros ProducaoRegistro[]
  logsOperacao LogOperacao[]
  contasPagar ContaPagar[]
  userInvites UserInvite[]
  authAuditLogs AuthAuditLog[]
}

model AdminUser {
  id         String   @id @default(uuid())
  tenantId   String
  nome       String
  username   String
  email      String?
  emailNormalizado String?
  passwordHash String
  criadoEm   DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, username])
  @@unique([tenantId, emailNormalizado])
  @@index([tenantId, emailNormalizado])
}

model UserInvite {
  id               String       @id @default(uuid())
  tenantId         String
  email            String
  emailNormalizado String
  tokenHash        String       @unique
  expiresAt        DateTime
  usedAt           DateTime?
  revokedAt        DateTime?
  createdAt        DateTime     @default(now())
  createdBy        String?
  status           InviteStatus @default(PENDING)

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, emailNormalizado, status])
  @@index([tenantId, expiresAt])
}

model AuthAuditLog {
  id          String          @id @default(uuid())
  tenantId    String?
  adminUserId String?
  inviteId    String?
  action      AuthAuditAction
  identifier  String?
  ipHash      String?
  userAgent   String?
  metadata    Json?
  createdAt   DateTime        @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@index([tenantId, action, createdAt])
  @@index([adminUserId, createdAt])
  @@index([inviteId])
}
