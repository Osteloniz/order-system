# Neon (Postgres)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
# Para producao, crie um arquivo local .env.prod com as credenciais da branch de producao do Neon.

# NextAuth
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
APP_URL="http://localhost:3000"
# Para testar checkout Asaas localmente, APP_URL precisa apontar para uma URL publica temporaria do tunel.
# Se a sua chave do Asaas comecar com $, escape no .env local como \$
ASAAS_ENV="sandbox"
ASAAS_API_KEY=""
ASAAS_WEBHOOK_TOKEN=""
ASAAS_CHECKOUT_EXPIRY_MINUTES="60"
ADMIN_ACCESS_KEY=""
TOKEN_PEPPER=""
BCRYPT_ROUNDS="12"
INVITE_EXPIRY_HOURS="24"
LOG_LEVEL="info"
ENABLE_OPERATION_LOGS="true"
LOG_OPERATION_RETENTION_DAYS="90"
AUTH_AUDIT_RETENTION_DAYS="180"

# Seed
SEED_ADMIN_PASSWORD="admin123"
